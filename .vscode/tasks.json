{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Postgres (Docker)",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Create venv",
      "type": "shell",
      "command": "python3 -m venv .venv",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Install requirements",
      "type": "shell",
      "command": ".venv/bin/python -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": [
        "Start Postgres (Docker)",
        "Create venv"
      ],
      "group": "build"
    }
  ]
}